config dufs 'main'
	option enabled '0'
	option serve_path '/mnt'
	list bind '0.0.0.0'
	option port '5000'
	option path_prefix ''
	option allow_all '0'
	option allow_upload '0'
	option allow_delete '0'
	option allow_search '0'
	option allow_symlink '0'
	option allow_archive '0'
	option allow_hash '0'
	option enable_cors '0'
	option render_index '0'
	option render_try_index '0'
	option render_spa '0'
	option compress 'low'
	option user 'root'
	option group 'root'
